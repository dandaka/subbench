{
  "name": "subbench",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "subbench": "bun run packages/cli/src/index.ts",
    "select:tasks": "bun run scripts/select-deepswe-tasks.ts",
    "calibrate:openai": "bun run scripts/run-deepswe-calibration.ts",
    "calibrate:zai": "bun run scripts/run-zai-deepswe-calibration.ts",
    "test": "bun test",
    "typecheck": "tsc --build",
    "check": "bun run typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}
